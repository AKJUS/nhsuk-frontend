{% extends "layouts/page-full-width.njk" %}

{% set pageName = "Icons" %}

{% set icons = [
  { name: "Arrow left", modifier: "arrow-left" },
  { name: "Arrow right", modifier: "arrow-right" },
  { name: "Arrow up", modifier: "arrow-up" },
  { name: "Arrow down", modifier: "arrow-down" },
  { name: "Arrow left circle", modifier: "arrow-left-circle" },
  { name: "Arrow right circle", modifier: "arrow-right-circle" },
  { name: "Arrow up circle", modifier: "arrow-up-circle" },
  { name: "Arrow down circle", modifier: "arrow-down-circle" },
  { name: "Chevron left circle", modifier: "chevron-left-circle" },
  { name: "Chevron right circle", modifier: "chevron-right-circle" },
  { name: "Chevron up circle", modifier: "chevron-up-circle" },
  { name: "Chevron down circle", modifier: "chevron-down-circle" },
  { name: "Cross", modifier: "cross" },
  { name: "Tick", modifier: "tick" },
  { name: "Minus", modifier: "minus" },
  { name: "Plus", modifier: "plus" },
  { name: "Search", modifier: "search" },
  { name: "User", modifier: "user" }
] %}

{% block beforeContent %}
  {{ breadcrumb({
    items: [
      {
        text: "NHS.UK frontend",
        href: baseUrl
      },
      {
        text: "Examples",
        href: baseUrl ~ "#examples"
      }
    ]
  }) }}
{% endblock %}

{% block content %}
  <section class="nhsuk-main-wrapper nhsuk-main-wrapper--s">
    <div class="nhsuk-width-container">

      <div class="nhsuk-grid-row">
        <div class="nhsuk-grid-column-two-thirds">
          <h1 class="nhsuk-heading-xl">{{ pageName }}</h1>
        </div>
      </div>

      <div class="nhsuk-grid-row">
        <div class="nhsuk-grid-column-full">
          {% set rows = [] %}

          {% for icon in icons %}
            {% set modifierHtml %}
              <var class="nhsuk-body-s">{{ icon.modifier }}</var>
            {% endset %}

            {% set iconHtml %}
              {% for size, params in {
                "100%": {},
                "125%": { size: 25 },
                "150%": { size: 50 },
                "175%": { size: 75 },
                "200%": { size: 100 }
              } %}
                <figure class="nhsuk-u-display-inline-block nhsuk-u-text-align-centre nhsuk-u-margin-1">
                  {{ nhsukIcon(icon.modifier, params) }}
                  <figcaption class="nhsuk-body-s">{{ size }}</figcaption>
                </figure>
              {% endfor %}
            {% endset %}

            {% set rows = (rows.push([
              { text: icon.name, header: "Name" },
              { html: modifierHtml, header: "Modifier" },
              { text: iconHtml | safe }
            ]), rows) %}
          {% endfor %}

          {{ table({
            caption: "Page background",
            captionClasses: "nhsuk-u-margin-bottom-4",
            captionSize: "l",
            firstCellIsHeader: true,
            responsive: true,
            head: [
              {
                text: "Name",
                classes: "nhsuk-u-width-one-quarter"
              },
              {
                text: "Modifier",
                classes: "nhsuk-u-width-one-quarter"
              },
              {
                text: "Icon",
                classes: "nhsuk-u-width-one-half"
              }
            ],
            rows: rows
          }) }}

        </div>
      </div>

    </div>
  </section>

  <section class="nhsuk-main-wrapper app-wrapper app-wrapper--background-blue">
    <div class="nhsuk-width-container">

      <div class="nhsuk-grid-row">
        <div class="nhsuk-grid-column-full">
          {% set rows = [] %}

          {% for icon in icons %}
            {% set modifierHtml %}
              <var class="nhsuk-body-s">{{ icon.modifier }}</var>
            {% endset %}

            {% set iconHtml %}
              {% for size, params in {
                "100%": {},
                "125%": { classes: "nhsuk-icon--size-25" },
                "150%": { classes: "nhsuk-icon--size-50" },
                "175%": { classes: "nhsuk-icon--size-75" },
                "200%": { classes: "nhsuk-icon--size-100" }
              } %}
                <figure class="nhsuk-u-display-inline-block nhsuk-u-text-align-centre nhsuk-u-margin-1">
                  {{ nhsukIcon(icon.modifier, params) }}
                  <figcaption class="nhsuk-body-s">{{ size }}</figcaption>
                </figure>
              {% endfor %}
            {% endset %}

            {% set rows = (rows.push([
              { text: icon.name, header: "Name" },
              { html: modifierHtml, header: "Modifier" },
              { text: iconHtml | safe }
            ]), rows) %}
          {% endfor %}

          {{ table({
            caption: "Blue background (used in hero)",
            captionClasses: "nhsuk-u-margin-bottom-4",
            captionSize: "l",
            variant: "reverse",
            firstCellIsHeader: true,
            responsive: true,
            head: [
              {
                text: "Name",
                classes: "nhsuk-u-width-one-quarter"
              },
              {
                text: "Modifier",
                classes: "nhsuk-u-width-one-quarter"
              },
              {
                text: "Icon",
                classes: "nhsuk-u-width-one-half"
              }
            ],
            rows: rows
          }) }}

        </div>
      </div>

    </div>
  </section>
{% endblock %}
