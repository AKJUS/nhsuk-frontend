{% extends "layouts/page.njk" %}

{% set pageName = "Form elements alignment" %}
{% set mainClasses = "nhsuk-main-wrapper--s" %}

{% block beforeContent %}
  {{ breadcrumb({
    items: [
      {
        text: "NHS.UK frontend",
        href: baseUrl
      },
      {
        text: "Examples",
        href: baseUrl ~ "#examples"
      }
    ]
  }) }}
{% endblock %}

{% block content %}
  <div class="nhsuk-grid-row">
    <div class="nhsuk-grid-column-two-thirds">
      <h1 class="nhsuk-heading-xl">{{ pageName }}</h1>
    </div>
  </div>

  <div class="nhsuk-grid-row">
    <div class="nhsuk-grid-column-full">

      <form method="post" novalidate>
        {% call fieldset({
          legend: {
            text: "Search input",
            size: "m"
          }
        }) %}
          {{ searchInput({
            label: {
              text: "Search patients by NHS number",
              classes: "nhsuk-u-visually-hidden"
            },
            placeholder: "NHS number",
            id: "example-search-1",
            name: "example-search-1",
            classes: "nhsuk-u-width-full",
            formGroup: {
              classes: "nhsuk-u-width-one-half"
            },
            button: false
          }) }}

          {{ searchInput({
            label: {
              text: "Search patients by NHS number",
              classes: "nhsuk-u-visually-hidden"
            },
            placeholder: "NHS number",
            id: "example-search-2",
            name: "example-search-2",
            classes: "nhsuk-u-width-full",
            formGroup: {
              classes: "nhsuk-u-width-one-half"
            }
          }) }}

          {{ searchInput({
            label: {
              text: "Search patients by NHS number",
              classes: "nhsuk-u-visually-hidden"
            },
            placeholder: "NHS number",
            id: "example-search-3",
            name: "example-search-3",
            classes: "nhsuk-u-width-full",
            large: true,
            formGroup: {
              classes: "nhsuk-u-width-one-half"
            }
          }) }}

          {{ searchInput({
            label: {
              text: "Search patients by NHS number",
              classes: "nhsuk-u-visually-hidden"
            },
            placeholder: "NHS number",
            id: "example-search-4",
            name: "example-search-4",
            classes: "nhsuk-u-width-full",
            formGroup: {
              classes: "nhsuk-u-width-one-half",
              afterInput: {
                html: button({
                  text: "Advanced search",
                  variant: "secondary",
                  small: true
                })
              }
            }
          }) }}

          {{ searchInput({
            label: {
              text: "Search patients by NHS number",
              classes: "nhsuk-u-visually-hidden"
            },
            placeholder: "NHS number",
            id: "example-search-5",
            name: "example-search-5",
            classes: "nhsuk-u-width-full",
            large: true,
            formGroup: {
              classes: "nhsuk-u-width-one-half",
              afterInput: {
                html: button({
                  text: "Advanced search",
                  variant: "secondary"
                })
              }
            }
          }) }}
        {% endcall %}
      </form>

      <form method="post" novalidate>
        {% call fieldset({
          legend: {
            text: "Search input with prefix",
            size: "m"
          }
        }) %}
          {{ searchInput({
            label: {
              text: "Code lookup",
              classes: "nhsuk-u-visually-hidden"
            },
            prefix: {
              text: "SNOMED"
            },
            placeholder: "Code",
            id: "example-search-6",
            name: "example-search-6",
            value: "160245001",
            code: true,
            classes: "nhsuk-u-width-full",
            button: {
              icon: "arrow-right",
              variant: "brand"
            },
            formGroup: {
              classes: "nhsuk-u-width-one-half"
            }
          }) }}

          {{ searchInput({
            label: {
              text: "Code lookup",
              classes: "nhsuk-u-visually-hidden"
            },
            prefix: {
              text: "ATC"
            },
            placeholder: "Code",
            id: "example-search-7",
            name: "example-search-7",
            value: "A02BC01",
            code: true,
            classes: "nhsuk-u-width-full",
            button: {
              icon: "arrow-right",
              variant: "brand"
            },
            formGroup: {
              classes: "nhsuk-u-width-one-half"
            }
          }) }}
        {% endcall %}
      </form>

      <form method="post" novalidate>
        {% call fieldset({
          legend: {
            text: "Input and icon button",
            size: "m"
          }
        }) %}
          {{ input({
            label: {
              text: "Product order number"
            },
            id: "example-input-button-1",
            name: "example-input-button-1",
            type: "search",
            classes: "nhsuk-u-width-full",
            formGroup: {
              classes: "nhsuk-u-width-one-half",
              afterInput: {
                html: button({
                  text: "Continue",
                  icon: {
                    name: "arrow-right",
                    placement: "end"
                  },
                  small: true
                })
              }
            }
          }) }}

          {{ input({
            label: {
              text: "Product order number"
            },
            id: "example-input-button-2",
            name: "example-input-button-2",
            type: "search",
            classes: "nhsuk-u-width-full",
            formGroup: {
              classes: "nhsuk-u-width-one-half",
              afterInput: {
                html: button({
                  ariaLabel: "Continue",
                  icon: "arrow-right",
                  small: true
                })
              }
            }
          }) }}

          {{ input({
            label: {
              text: "Product order number"
            },
            id: "example-input-button-3",
            name: "example-input-button-3",
            type: "search",
            classes: "nhsuk-u-width-full",
            formGroup: {
              classes: "nhsuk-u-width-one-half",
              afterInput: {
                html: button({
                  text: "Accept",
                  variant: "secondary",
                  icon: "tick",
                  small: true
                })
              }
            }
          }) }}

          {{ input({
            label: {
              text: "Product order number"
            },
            id: "example-input-button-4",
            name: "example-input-button-4",
            type: "search",
            classes: "nhsuk-u-width-full",
            formGroup: {
              classes: "nhsuk-u-width-one-half",
              afterInput: {
                html: button({
                  ariaLabel: "Accept",
                  variant: "secondary",
                  icon: "tick",
                  small: true
                })
              }
            }
          }) }}
        {% endcall %}
      </form>

      <form method="post" novalidate>
        {% call fieldset({
          legend: {
            text: "Input and button",
            size: "m"
          }
        }) %}
          {{ input({
            label: {
              text: "NHS number"
            },
            id: "example-input-1",
            name: "example-input-1",
            classes: "nhsuk-u-width-full",
            code: true,
            inputmode: "numeric",
            spellcheck: false,
            formGroup: {
              classes: "nhsuk-u-width-one-half",
              afterInput: {
                html: button({
                  text: "Search",
                  variant: "secondary",
                  small: true
                })
              }
            }
          }) }}
        {% endcall %}
      </form>

      <form method="post" novalidate>
        {% call fieldset({
          legend: {
            text: "Input and button with error",
            size: "m"
          }
        }) %}
          {{ input({
            label: {
              text: "NHS number"
            },
            errorMessage: {
              text: "Enter an NHS number"
            },
            id: "example-input-2",
            name: "example-input-2",
            classes: "nhsuk-u-width-full",
            code: true,
            inputmode: "numeric",
            spellcheck: false,
            formGroup: {
              classes: "nhsuk-u-width-one-half",
              afterInput: {
                html: button({
                  text: "Search",
                  variant: "secondary",
                  small: true
                })
              }
            }
          }) }}
        {% endcall %}
      </form>

      <form method="post" novalidate>
        {% call fieldset({
          legend: {
            text: "Select and button",
            size: "m"
          }
        }) %}
          {{ select({
            label: {
              text: "Sort by"
            },
            id: "sort-by",
            name: "sort-by",
            classes: "nhsuk-u-width-full",
            items: [
              {
                value: "published",
                text: "Recently published"
              },
              {
                value: "updated",
                text: "Recently updated"
              },
              {
                value: "views",
                text: "Most views"
              },
              {
                value: "comments",
                text: "Most comments"
              }
            ],
            formGroup: {
              classes: "nhsuk-u-width-one-half",
              afterInput: {
                html: button({
                  text: "Sort",
                  variant: "secondary",
                  small: true
                })
              }
            }
          }) }}
        {% endcall %}
      </form>

      <form method="post" novalidate>
        {% call fieldset({
          legend: {
            text: "Select and button with error",
            size: "m"
          }
        }) %}
          {{ select({
            label: {
              text: "Sort by"
            },
            errorMessage: {
              text: "Select sort by"
            },
            id: "sort-by-2",
            name: "sort-by-2",
            classes: "nhsuk-u-width-full",
            items: [
              {
                value: "published",
                text: "Recently published"
              },
              {
                value: "updated",
                text: "Recently updated"
              },
              {
                value: "views",
                text: "Most views"
              },
              {
                value: "comments",
                text: "Most comments"
              }
            ],
            formGroup: {
              classes: "nhsuk-u-width-one-half",
              afterInput: {
                html: button({
                  text: "Sort",
                  variant: "secondary",
                  small: true
                })
              }
            }
          }) }}
        {% endcall %}
      </form>

      <form method="post" novalidate>
        {% call fieldset({
          legend: {
            text: "Inputs side by side",
            size: "m"
          }
        }) %}
          <div class="nhsuk-form-group nhsuk-form-group--inline nhsuk-u-width-two-thirds">
            {{ input({
              label: {
                text: "Stone"
              },
              suffix: {
                text: "st"
              },
              id: "weight-stone",
              name: "weight-stone"
            }) }}

            {{ input({
              label: {
                text: "Pounds"
              },
              suffix: {
                text: "lb"
              },
              id: "weight-pound",
              name: "weight-pound"
            }) }}
          </div>
        {% endcall %}
      </form>

      <form method="post" novalidate>
        {% call fieldset({
          legend: {
            text: "Input and select",
            size: "m"
          }
        }) %}
          <div class="nhsuk-form-group nhsuk-form-group--inline nhsuk-u-width-two-thirds">
            {{ input({
              label: {
                text: "Keywords"
              },
              id: "keywords-group",
              name: "keywords-group"
            }) }}

            {{ select({
              label: {
                text: "Sort by"
              },
              id: "sort-by-group",
              name: "sort-by-group",
              items: [
                {
                  value: "published",
                  text: "Recently published"
                },
                {
                  value: "updated",
                  text: "Recently updated"
                },
                {
                  value: "views",
                  text: "Most views"
                },
                {
                  value: "comments",
                  text: "Most comments"
                }
              ]
            }) }}
          </div>
        {% endcall %}
      </form>

      <form method="post" novalidate>
        {% call fieldset({
          legend: {
            text: "Input and checkboxes",
            size: "m"
          }
        }) %}
          <div class="nhsuk-form-group nhsuk-form-group--inline">
            {{ input({
              label: {
                text: "Keywords"
              },
              id: "keywords-checkboxes",
              name: "keywords-checkboxes",
              formGroup: {
                classes: "nhsuk-u-width-one-third"
              }
            }) }}

            {{ checkboxes({
              idPrefix: "checkboxes",
              name: "checkboxes",
              items: [
                {
                  text: "Show archived",
                  value: "archived"
                }
              ]
            }) }}
          </div>
          <div class="nhsuk-form-group nhsuk-form-group--inline">
            {{ input({
              label: {
                text: "Keywords"
              },
              id: "keywords-checkboxes-small",
              name: "keywords-checkboxes-small",
              formGroup: {
                classes: "nhsuk-u-width-one-third"
              }
            }) }}

            {{ checkboxes({
              idPrefix: "checkboxes-small",
              name: "checkboxes-small",
              small: true,
              items: [
                {
                  text: "Show archived",
                  value: "archived"
                }
              ]
            }) }}
          </div>
        {% endcall %}
      </form>

      <form method="post" novalidate>
        {% call fieldset({
          legend: {
            text: "Input and radios",
            size: "m"
          }
        }) %}
          <div class="nhsuk-form-group nhsuk-form-group--inline">
            {{ input({
              label: {
                text: "Keywords"
              },
              id: "keywords-radios",
              name: "keywords-radios",
              formGroup: {
                classes: "nhsuk-u-width-one-third"
              }
            }) }}

            {{ radios({
              idPrefix: "radios",
              name: "radios",
              items: [
                {
                  text: "Not applicable",
                  value: "na"
                }
              ]
            }) }}
          </div>
          <div class="nhsuk-form-group nhsuk-form-group--inline">
            {{ input({
              label: {
                text: "Keywords"
              },
              id: "keywords-radios-small",
              name: "keywords-radios-small",
              formGroup: {
                classes: "nhsuk-u-width-one-third"
              }
            }) }}

            {{ radios({
              idPrefix: "radios-small",
              name: "radios-small",
              small: true,
              items: [
                {
                  text: "Not applicable",
                  value: "na"
                }
              ]
            }) }}
          </div>
        {% endcall %}
      </form>

      <form method="post" novalidate>
        {% call fieldset({
          legend: {
            text: "Checkboxes and radios",
            size: "m"
          }
        }) %}
          <div class="nhsuk-form-group nhsuk-form-group--inline">
            {{ checkboxes({
              idPrefix: "checkboxes-group",
              name: "checkboxes-group",
              items: [
                {
                  text: "Show archived",
                  value: "archived"
                }
              ]
            }) }}

            {{ radios({
              idPrefix: "radios-group",
              name: "radios-group",
              items: [
                {
                  text: "Not applicable",
                  value: "na"
                }
              ]
            }) }}
          </div>
          <div class="nhsuk-form-group nhsuk-form-group--inline">
            {{ checkboxes({
              idPrefix: "checkboxes-group-small",
              name: "checkboxes-group-small",
              small: true,
              items: [
                {
                  text: "Show archived",
                  value: "archived"
                }
              ]
            }) }}

            {{ radios({
              idPrefix: "radios-group-small",
              name: "radios-group-small",
              small: true,
              items: [
                {
                  text: "Not applicable",
                  value: "na"
                }
              ]
            }) }}
          </div>
        {% endcall %}
      </form>

      <form method="post" novalidate>
        {% call fieldset({
          legend: {
            text: "Input with nhsuk-u-width classes",
            size: "m"
          }
        }) %}
          {{ input({
            label: {
              text: "Input with nhsuk-u-width-one-quarter (25% width)"
            },
            id: "width-one-quarter",
            name: "width-one-quarter",
            classes: "nhsuk-u-width-one-quarter"
          }) }}

          {{ input({
            label: {
              text: "Input with nhsuk-u-width-one-third (33% width)"
            },
            id: "width-one-third",
            name: "width-one-third",
            classes: "nhsuk-u-width-one-third"
          }) }}

          {{ input({
            label: {
              text: "Input with nhsuk-u-width-one-half (50% width)"
            },
            id: "width-one-half",
            name: "width-one-half",
            classes: "nhsuk-u-width-one-half"
          }) }}

          {{ input({
            label: {
              text: "Input with nhsuk-u-width-two-thirds (66% width)"
            },
            id: "width-two-thirds",
            name: "width-two-thirds",
            classes: "nhsuk-u-width-two-thirds"
          }) }}

          {{ input({
            label: {
              text: "Input with nhsuk-u-width-three-quarters (75% width)"
            },
            id: "width-three-quarters",
            name: "width-three-quarters",
            classes: "nhsuk-u-width-three-quarters"
          }) }}

          {{ input({
            label: {
              text: "Input with nhsuk-u-width-full (100% width)"
            },
            id: "width-full",
            name: "width-full",
            classes: "nhsuk-u-width-full"
          }) }}
        {% endcall %}

        {{ button({
          text: "Continue"
        }) }}
      </form>
    </div>
  </div>
{% endblock %}
